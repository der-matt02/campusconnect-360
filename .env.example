# ============================================================
#  CampusConnect 360 — Variables de entorno (ejemplo)
#  Copia este archivo a .env y ajusta los valores.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=campus
POSTGRES_PASSWORD=campus_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Bases de datos por servicio (una por microservicio)
DB_ACADEMICO=academico_db
DB_PAGOS=pagos_db
DB_ASISTENCIA=asistencia_db
DB_NOTIFICACIONES=notificaciones_db
DB_ANALITICA=analitica_db

# ---------- RabbitMQ ----------
RABBITMQ_USER=campus
RABBITMQ_PASSWORD=campus_secret
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Exchange y cola de mensajes muertos (DLQ)
EVENTS_EXCHANGE=campusconnect.events
DLX_EXCHANGE=campusconnect.dlx

# ---------- Seguridad (JWT) ----------
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# ---------- URLs internas de servicios (usadas por el Gateway) ----------
ACADEMICO_URL=http://academico:8001
PAGOS_URL=http://pagos:8002
NOTIFICACIONES_URL=http://notificaciones:8003
ASISTENCIA_URL=http://asistencia:8004
ANALITICA_URL=http://analitica:8005
